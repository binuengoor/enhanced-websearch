EWS_MCP_REQUEST_TIMEOUT=90
EWS_AUTH_ENABLED=false
EWS_AUTH_TOKEN=

# Provider and integration endpoints
SEARXNG_BASE_URL=http://searxng:8080
LITELLM_SEARCH_BASE_URL=http://litellm:4000
LITELLM_API_KEY=

FLARESOLVERR_URL=
VANE_URL=http://vane:3000

# Provider-specific keys are not required when LiteLLM uses one gateway key.

# Vane proxy settings used by /research
VANE_CHAT_PROVIDER_ID=
VANE_EMBED_PROVIDER_ID=
VANE_CHAT_MODEL_KEY=auto-main
VANE_EMBED_MODEL_KEY=Xenova/nomic-embed-text-v1

# MCP transport security allowlist (comma-separated)
# Include your LAN IP/domain if MCP clients connect via that host.
EWS_MCP_ALLOWED_HOSTS=127.0.0.1:*,localhost:*,[::1]:*,10.1.1.150:*
EWS_MCP_ALLOWED_ORIGINS=http://127.0.0.1:*,http://localhost:*,http://[::1]:*,http://10.1.1.150:*,https://10.1.1.150:*
# Optional: set to false only for debugging in trusted networks.
EWS_MCP_DNS_REBINDING_PROTECTION=true
